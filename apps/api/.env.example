NODE_ENV=development
PORT=4000

# ---- Database ----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hoobiq?schema=public"
REDIS_URL="redis://localhost:6379"

# ---- Auth (generate with: openssl rand -base64 48) ----
SESSION_COOKIE_NAME=hbq_session
SESSION_SECRET=REPLACE_ME_with_at_least_32_chars_of_random_base64
SESSION_TTL_DAYS=30
# PASSWORD_PEPPER adds a per-deploy secret to bcrypt so DB-only dumps can't be brute-forced
PASSWORD_PEPPER=REPLACE_ME_with_16plus_chars_of_random
# CSRF token secret (separate from session secret)
CSRF_SECRET=REPLACE_ME_with_at_least_32_chars_of_random

# ---- CORS origins (comma-separated) ----
WEB_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3001

# ---- Midtrans (sandbox) ----
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_SIGNATURE_KEY=

# ---- Komerce (sandbox) ----
KOMERCE_API_KEY=
KOMERCE_WEBHOOK_SECRET=

# ---- Cloudflare R2 ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=hoobiq-sandbox
R2_PUBLIC_URL=

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
