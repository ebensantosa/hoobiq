# ===========================================================================
# Hoobiq Web — production environment template
# Copy to /var/www/hoobiq/apps/web/.env on the VPS.
# ===========================================================================

NODE_ENV=production

# Public API URL — visible to browsers. Must include /api/v1 prefix.
NEXT_PUBLIC_API_URL=https://api.hoobiq.com/api/v1

# Internal API URL — used by Next.js server-side rendering. Same machine,
# faster path (skip Caddy + TLS round trip). Used by serverApi() helper.
INTERNAL_API_URL=http://127.0.0.1:4000/api/v1
