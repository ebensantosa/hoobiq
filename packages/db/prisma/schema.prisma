// Hoobiq — marketplace & komunitas kolektor Indonesia
// Postgres for both dev and prod (swap to local Postgres via DATABASE_URL).
// SQLite was used during early prototyping; we moved to Postgres so dev
// behavior matches production exactly (booleans, transactions, json types).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  username       String    @unique
  email          String    @unique
  emailVerified  DateTime?
  passwordHash   String    @map("password_hash")
  phone          String?
  name           String?
  avatarUrl      String?   @map("avatar_url")
  bio            String?
  city           String?
  role           String    @default("user")
  status         String    @default("active")
  trustScore     Float     @default(0) @map("trust_score")
  exp            Int       @default(0)
  level          Int       @default(1)
  ktpVerified    Boolean   @default(false) @map("ktp_verified")
  twoFAEnabled   Boolean   @default(false) @map("twofa_enabled")
  twoFASecret    String?   @map("twofa_secret")
  // Soft cooldown for password changes — UI + API enforce a minimum
  // gap between changes via this timestamp.
  lastPasswordChangeAt DateTime? @map("last_password_change_at")
  // Email verification — single-use token sent at register time. We
  // store sha256(rawToken) so a DB dump alone can't impersonate; the
  // user clicks a link with the raw token, the verify endpoint hashes
  // it again, looks the row up, and sets emailVerified on match.
  emailVerificationTokenHash      String?   @map("email_verification_token_hash")
  emailVerificationExpiresAt      DateTime? @map("email_verification_expires_at")
  // Password reset — same hash-only-store pattern as email verify.
  // 30-min expiry. Reset endpoint also revokes every active session
  // so an attacker who triggered the flow can't keep an existing
  // session alive after the legitimate user resets.
  passwordResetTokenHash          String?   @map("password_reset_token_hash")
  passwordResetExpiresAt          DateTime? @map("password_reset_expires_at")
  // KTP verification tracking. `ktpVerified` is the existing simple
  // flag; the timestamp lets the UI show "verified on …" and the
  // status field carries pending/rejected nuance for moderation.
  ktpStatus      String    @default("none") @map("ktp_status") // none | pending | verified | rejected
  ktpSubmittedAt DateTime? @map("ktp_submitted_at")
  ktpVerifiedAt  DateTime? @map("ktp_verified_at")
  ktpRejectNote  String?   @map("ktp_reject_note")
  ktpFrontUrl    String?   @map("ktp_front_url")
  ktpSelfieUrl   String?   @map("ktp_selfie_url")
  // Identity fields the seller fills in alongside the photos so an
  // admin can cross-check the KTP image. Stored as plain text since
  // they need to be readable side-by-side with the photo during
  // review; sensitive enough that we never expose them publicly.
  ktpFullName    String?   @map("ktp_full_name")
  ktpNik         String?   @map("ktp_nik")
  ktpDob         String?   @map("ktp_dob")
  ktpAddress     String?   @map("ktp_address")
  interestedJson String    @default("[]") @map("interested_json")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  sessions         Session[]
  listings         Listing[]       @relation("SellerListings")
  ordersAsBuyer    Order[]         @relation("BuyerOrders")
  ordersAsSeller   Order[]         @relation("SellerOrders")
  addresses        Address[]
  bankAccounts     BankAccount[]
  wishlist         WishlistItem[]
  postsAuthored    Post[]
  cartItems        CartItem[]
  categoryRequestsSubmitted CategoryRequest[] @relation("CategoryRequestUser")
  categoryRequestsDecided   CategoryRequest[] @relation("CategoryRequestDecider")
  disputesAsBuyer  Dispute[]       @relation("BuyerDisputes")
  disputesAsSeller Dispute[]       @relation("SellerDisputes")
  reportsFiled     Report[]        @relation("ReporterReports")
  notifications    Notification[]
  auditEntries     AuditEntry[]
  listingReviews   ListingReview[] @relation("BuyerReviews")
  payoutRequests   PayoutRequest[] @relation("PayoutUser")
  payoutDecisions  PayoutRequest[] @relation("PayoutDecider")
  orderMessages    OrderMessage[]  @relation("OrderMessageSender")
  follows          UserFollow[]    @relation("FollowerUser")
  followers        UserFollow[]    @relation("FollowedUser")
  expAwards        ExpAward[]
  // Premium membership state. `isPremium=true` while premiumUntil is in
  // the future; the runtime treats them as a pair. premiumStartedAt is
  // kept for analytics (renewal cadence, churn).
  isPremium        Boolean   @default(false) @map("is_premium")
  premiumUntil     DateTime? @map("premium_until")
  premiumStartedAt DateTime? @map("premium_started_at")
  // Daily check-in (last successful claim). Used both for streak math
  // (future) and to gate the +exp grant to once-per-UTC-day.
  lastDailyCheckinAt DateTime? @map("last_daily_checkin_at")
  membershipUsage  MembershipUsage[]

  @@index([email])
  @@index([username])
  @@index([status, trustScore])
  @@map("users")
}

/// One row per premium-subscription purchase. Mirrors the BoostPurchase
/// pattern: create pending → fire Midtrans Snap → webhook flips status
/// to paid and extends `User.premiumUntil`. providerTxId carries the
/// "PRM-" prefix so the webhook router can dispatch to membership.
model MembershipPurchase {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  months       Int
  priceCents   BigInt    @map("price_cents")
  providerTxId String    @unique @map("provider_tx_id")
  status       String    @default("pending") // pending | paid | failed | cancelled
  paidAt       DateTime? @map("paid_at")
  startsAt     DateTime? @map("starts_at")
  endsAt       DateTime? @map("ends_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([userId, createdAt])
  @@index([status])
  @@map("membership_purchases")
}

/// Per-user, per-month counter of consumable membership perks (free
/// boost slots, free ongkir slots). Period is "YYYY-MM" UTC. We
/// increment usage atomically when the user claims a perk so a
/// double-click doesn't grant two boosts. Resets are implicit: the
/// next month's row is auto-created on first claim.
model MembershipUsage {
  userId      String   @map("user_id")
  period      String
  boostUsed   Int      @default(0) @map("boost_used")
  ongkirUsed  Int      @default(0) @map("ongkir_used")
  voucherUsed Int      @default(0) @map("voucher_used")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, period])
  @@map("membership_usage")
}

/// EXP grant ledger. One row per award; idempotent grants use a
/// dedupeKey (e.g. "once" for first-time awards or "daily:YYYY-MM-DD"
/// for once-per-day) so retries are no-ops. Awards without a dedupeKey
/// are unbounded (NULLs are not equal under unique constraints, so
/// multiple rows with the same user+kind+null are allowed).
model ExpAward {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  kind      String
  amount    Int
  dedupeKey String?  @map("dedupe_key")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, dedupeKey])
  @@index([userId, createdAt])
  @@index([userId, kind, createdAt])
  @@map("exp_awards")
}

/// Directed follow graph. (followerId → followedId) means the follower
/// gets the followed user's posts in their Following feed and shows up
/// in the followed user's followers count.
model UserFollow {
  followerId String   @map("follower_id")
  followedId String   @map("followed_id")
  createdAt  DateTime @default(now()) @map("created_at")

  follower User @relation("FollowerUser", fields: [followerId], references: [id], onDelete: Cascade)
  followed User @relation("FollowedUser", fields: [followedId], references: [id], onDelete: Cascade)

  @@id([followerId, followedId])
  @@index([followedId, createdAt])
  @@index([followerId, createdAt])
  @@map("user_follows")
}

model Session {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  userAgent String?   @map("user_agent")
  ip        String?
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("sessions")
}

model Address {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  label     String
  name      String
  phone     String
  line      String
  city      String
  province  String
  postal    String
  // Kelurahan (subdistrict) + kecamatan (district). Only auto-filled
  // when the user picks via the destination autocomplete; left blank
  // for legacy rows + manual entries. Surfaces on the order detail
  // page so couriers see the full Indonesian address hierarchy.
  subdistrict String? @map("subdistrict")
  district    String? @map("district")
  // RajaOngkir/Komerce subdistrict id — populated when buyer picks an
  // address via the destination autocomplete. Required for accurate ongkir
  // calculation; if missing, checkout falls back to a city-level estimate.
  subdistrictId Int? @map("subdistrict_id")
  primary   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId, primary])
  @@map("addresses")
}

model PayoutRequest {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  bankAccountId  String    @map("bank_account_id")
  amountCents    BigInt    @map("amount_cents")
  // pending | approved | rejected | paid | cancelled
  status         String    @default("pending")
  opsNote        String?   @map("ops_note")
  decidedById    String?   @map("decided_by_id")
  decidedAt      DateTime? @map("decided_at")
  paidAt         DateTime? @map("paid_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user      User @relation("PayoutUser",    fields: [userId],      references: [id], onDelete: Cascade)
  decidedBy User? @relation("PayoutDecider", fields: [decidedById], references: [id])

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("payout_requests")
}

model BankAccount {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  bank        String
  numberEnc   String   @map("number_enc")
  numberLast4 String   @map("number_last4")
  holderName  String   @map("holder_name")
  primary     Boolean  @default(false)
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("bank_accounts")
}

model Category {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  parentId  String?    @map("parent_id")
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  level     Int        @default(1)
  order     Int        @default(0)
  // Optional admin-uploaded hero image used by the home category strip
  // (and any future surface that wants a richer thumbnail than the icon).
  // Falls back to the slug-keyed icon + tone gradient when null.
  imageUrl  String?    @map("image_url")
  createdAt DateTime   @default(now()) @map("created_at")

  listings Listing[]
  requests CategoryRequest[]

  @@index([parentId])
  @@map("categories")
}

// User-submitted request to add a new sub-category (or sub-sub-category)
// to the catalog. The user picks a parent (must be an existing Category),
// proposes a name + suggested slug, and an admin either approves (which
// inserts a real Category and links it) or rejects. Approved requests
// carry `categoryId` pointing to the freshly-created row.
model CategoryRequest {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  parentId    String   @map("parent_id")
  name        String
  // Optional slug suggestion; admin can override on approve.
  slugHint    String?  @map("slug_hint")
  description String?
  status      String   @default("pending") // pending | approved | rejected
  rejectNote  String?  @map("reject_note")
  // Set when status flips to "approved" — points at the new Category.
  categoryId  String?  @map("category_id")
  decidedById String?  @map("decided_by_id")
  decidedAt   DateTime? @map("decided_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user     User      @relation("CategoryRequestUser",   fields: [userId],     references: [id], onDelete: Cascade)
  parent   Category  @relation(                          fields: [parentId],   references: [id])
  decidedBy User?    @relation("CategoryRequestDecider", fields: [decidedById],references: [id])
  listings Listing[]

  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@map("category_requests")
}

model Listing {
  id           String    @id @default(cuid())
  slug         String    @unique
  sellerId     String    @map("seller_id")
  categoryId   String    @map("category_id")
  title        String
  description  String
  priceCents   BigInt    @map("price_cents")
  // Optional "before" price for strike-through display. When non-null
  // and > priceCents, UI surfaces the discount badge (Hemat Rp X · -Y%)
  // on the card and detail page. Stored in cents to match priceCents.
  compareAtCents BigInt? @map("compare_at_cents")
  stock        Int       @default(1)
  condition    String
  imagesJson   String    @default("[]") @map("images_json")
  weightGrams  Int       @default(500) @map("weight_grams")
  // Optional package dimensions in centimetres. Surfaced on the listing
  // detail page when any of the three is set; couriers (JNE/JNT) charge
  // by volumetric weight on bulky-light items so admins / buyers want
  // to see the dimensions up front to spot mispriced ongkir.
  lengthCm     Int?      @map("length_cm")
  widthCm      Int?      @map("width_cm")
  heightCm     Int?      @map("height_cm")
  // Pre-order flag + seller-promised ship window in days (2–30). When
  // true, buyer pays now but the ship-by deadline becomes
  // paid_at + (preorderShipDays + 30) — sellers get a 30-day buffer
  // because PO has lots of legitimate disadvantages (manufacturer delay,
  // customs, redline). Cancel rules diverge: buyer can't cancel before
  // the deadline; once past it, buyer cancel always wins (24h auto).
  isPreorder       Boolean @default(false) @map("is_preorder")
  preorderShipDays Int?    @map("preorder_ship_days")
  // Variations (Shopee-style, single axis V1). When `hasVariants=true`,
  // the listing's own `stock` becomes the rolled-up sum of every
  // variant's stock — recomputed on save. Buyers MUST pick a variant
  // at checkout; markPaid decrements the picked variant's stock.
  hasVariants       Boolean @default(false) @map("has_variants")
  variantGroupName  String? @map("variant_group_name")
  variants          ListingVariant[]
  // Spec-block fields surfaced on the listing detail page. All optional:
  // not every category has a brand (toys yes, used komik usually no), and
  // varian/garansi only make sense for some items. Empty string treated
  // the same as null at render time.
  brand        String?
  variant      String?
  warranty     String?
  // Set when a seller created this listing with a brand-new
  // sub-category or series the marketplace doesn't have yet. The
  // listing stays at moderation="pending_category" / isPublished=false
  // until the linked CategoryRequest is approved by an admin; on
  // approval, the cascade in approveRequest() flips this listing
  // (and any siblings) to active + clears this column.
  categoryRequestId String? @map("category_request_id")
  // Owner has flagged this item as available for trade. When true the
  // listing surfaces in /trades deck for everyone (not just wishlist
  // matches). Doesn't disable purchase — buyers can still checkout normally.
  tradeable    Boolean   @default(false)
  // Seller-selected couriers this listing can be shipped via. JSON array of
  // courier codes ("jne", "jnt", ...) — kept as JSON string for SQLite/Postgres
  // portability. Empty/missing = no couriers configured (checkout will tell
  // the buyer to ask the seller).
  couriersJson String    @default("[]") @map("couriers_json")
  // RajaOngkir/Komerce subdistrict id of the seller's origin warehouse. Used
  // by /shipping/cost — if null we fall back to the seller's primary address
  // city, which is fuzzier and may overshoot ongkir.
  originSubdistrictId Int? @map("origin_subdistrict_id")
  boostedUntil DateTime? @map("boosted_until")
  views        Int       @default(0)
  // Seller controls whether this listing also appears on their public
  // profile feed (Pamer/koleksi tab). Some sellers want marketplace +
  // feed kept separate so a heavy listing schedule doesn't spam their
  // showcase. Defaults to true (most sellers want exposure); the form
  // surfaces a checkbox at upload time.
  showOnFeed   Boolean   @default(true) @map("show_on_feed")
  isPublished  Boolean   @default(false) @map("is_published")
  moderation   String    @default("pending")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  seller   User            @relation("SellerListings", fields: [sellerId], references: [id])
  category Category        @relation(fields: [categoryId], references: [id])
  categoryRequest CategoryRequest? @relation(fields: [categoryRequestId], references: [id])
  orders   Order[]
  wishes   WishlistItem[]
  reviews  ListingReview[]
  cartItems CartItem[]
  offerMessages Message[] @relation("MessageOfferListing")
  boostPurchases BoostPurchase[]

  @@index([sellerId, createdAt])
  @@index([categoryId, createdAt])
  @@index([isPublished, moderation, createdAt])
  @@index([boostedUntil])
  @@map("listings")
}

/// One option under a listing's single variation axis (Shopee-style).
/// Carries its own image, optional price override, and stock counter.
/// Order.variantId points here when the buyer picks a variant at
/// checkout, and markPaid decrements `stock` here (not the parent
/// listing's stock, which is just a roll-up).
model ListingVariant {
  id          String  @id @default(cuid())
  listingId   String  @map("listing_id")
  name        String
  description String?
  imageUrl    String? @map("image_url")
  /// Override price; null = use listing.priceCents.
  priceCents  BigInt? @map("price_cents")
  stock       Int     @default(0)
  order       Int     @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  orders  Order[]

  @@index([listingId, order])
  @@map("listing_variants")
}

// Persistent shopping cart. One row per (user, listing) — adding the
// same listing twice just bumps qty. Buyer can also adjust qty and
// remove items individually. Checkout reads from this table when the
// buyer hits the cart page; "Beli sekarang" still bypasses cart and
// goes straight to /checkout?listing=<slug> per the existing flow.
model CartItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  listingId String   @map("listing_id")
  qty       Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId, createdAt])
  @@map("cart_items")
}

// Buyer review tied to a completed order. One review per order so you can't
// spam-review the same listing. Star rating drives the listing's public
// rating score; the body is optional plain-text feedback.
model ListingReview {
  id        String   @id @default(cuid())
  listingId String   @map("listing_id")
  buyerId   String   @map("buyer_id")
  orderId   String   @unique @map("order_id")
  rating    Int // 1–5
  body      String?
  // Optional seller reply. Sellers can post a single reply per review
  // (subsequent saves overwrite). Surfaced under the review on the
  // listing detail page so buyers see the seller's response.
  sellerReply   String?   @map("seller_reply")
  sellerReplyAt DateTime? @map("seller_reply_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer   User    @relation("BuyerReviews", fields: [buyerId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([listingId, createdAt])
  @@index([buyerId, createdAt])
  @@map("listing_reviews")
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  listingId String   @map("listing_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@map("wishlist_items")
}

// Order status values (string literal — SQLite has no enums):
// pending_payment | paid | shipped | delivered | completed
// cancelled | refunded | returning | disputed | expired
//
// Timer fields drive auto-transitions handled by OrdersSchedulerService:
//  - shipmentDeadlineAt: 7 days after `paid`. If still not shipped → auto-cancel + refund.
//  - autoReleaseAt: 3 days after `delivered` (or buyer marks received). Funds released to seller.
model Order {
  id                 String    @id @default(cuid())
  humanId            String    @unique @map("human_id")
  buyerId            String    @map("buyer_id")
  sellerId           String    @map("seller_id")
  listingId          String    @map("listing_id")
  addressId          String    @map("address_id")
  qty                Int       @default(1)
  priceCents         BigInt    @map("price_cents")
  shippingCents      BigInt    @default(0) @map("shipping_cents")
  platformFeeCents   BigInt    @default(0) @map("platform_fee_cents")
  payFeeCents        BigInt    @default(0) @map("pay_fee_cents")
  insuranceCents     BigInt    @default(0) @map("insurance_cents")
  totalCents         BigInt    @map("total_cents")
  courierCode        String    @map("courier_code")
  trackingNumber     String?   @map("tracking_number")
  status             String    @default("pending_payment")
  paidAt             DateTime? @map("paid_at")
  shippedAt          DateTime? @map("shipped_at")
  deliveredAt        DateTime? @map("delivered_at")
  completedAt        DateTime? @map("completed_at")
  cancelledAt        DateTime? @map("cancelled_at")
  refundedAt         DateTime? @map("refunded_at")
  shipmentDeadlineAt DateTime? @map("shipment_deadline_at")
  autoReleaseAt      DateTime? @map("auto_release_at")
  // Pre-order specific. shipByAt is the deadline before which the buyer
  // CANNOT request cancel (paid_at + (preorderShipDays + 30 day buffer)).
  // Sellers can request one extension of up to 30 extra days with a
  // written reason — preorderExtraDays + preorderExtraReason carry the
  // approved extension; preorderExtensionAt records when it was granted.
  shipByAt              DateTime? @map("ship_by_at")
  preorderExtraDays     Int?      @map("preorder_extra_days")
  preorderExtraReason   String?   @map("preorder_extra_reason")
  preorderExtensionAt   DateTime? @map("preorder_extension_at")
  /// Variant pilihan buyer di checkout (kalau listing.hasVariants).
  /// Stock yang di-decrement waktu paid = ListingVariant.stock, bukan
  /// Listing.stock (yang cuma roll-up).
  variantId          String?   @map("variant_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  buyer          User            @relation("BuyerOrders", fields: [buyerId], references: [id])
  seller         User            @relation("SellerOrders", fields: [sellerId], references: [id])
  listing        Listing         @relation(fields: [listingId], references: [id])
  variant        ListingVariant? @relation(fields: [variantId], references: [id])
  address        Address         @relation(fields: [addressId], references: [id])
  payment        Payment?
  dispute        Dispute?
  review         ListingReview?
  cancelRequests CancelRequest[]
  returnRequests ReturnRequest[]
  messages       OrderMessage[]

  @@index([buyerId, status, createdAt])
  @@index([sellerId, status, createdAt])
  @@index([status, autoReleaseAt])
  @@index([status, shipmentDeadlineAt])
  @@map("orders")
}

/// Escrow chat thread attached to an Order. Buyer + seller post text
/// messages; the system auto-inserts events on every status change
/// (payment received, shipped + resi, cancel/return/dispute, etc.) so
/// the timeline reads as a single combined transcript. Admin reads
/// via the existing dispute view; V1 doesn't let admin post.
model OrderMessage {
  id              String   @id @default(cuid())
  orderId         String   @map("order_id")
  /// Null when this row is a system-generated event (paid, shipped,
  /// cancel-requested, etc.). User messages always carry the sender.
  senderId        String?  @map("sender_id")
  /// "user"  — typed by buyer or seller.
  /// "system" — auto-generated event from orders.service status changes.
  /// "admin"  — posted by an admin/ops user (intervention, clarification).
  kind            String   @default("user")
  body            String
  /// Image attachment URLs (R2 / local /uploads/evidence). Empty array
  /// when the message is text-only. JSON-encoded array of strings —
  /// matches the imagesJson pattern used elsewhere in the schema.
  imagesJson      String   @default("[]") @map("images_json")
  /// Per-side read receipts. Each side stamps its own column when it
  /// opens the thread or scrolls to a new message.
  readByBuyerAt   DateTime? @map("read_by_buyer_at")
  readBySellerAt  DateTime? @map("read_by_seller_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sender  User? @relation("OrderMessageSender", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@map("order_messages")
}

/// Buyer-initiated cancel request. Allowed only while order has not been
/// shipped (no resi yet). Status flow:
///   pending → accepted (seller acc → order cancelled + refund)
///           → rejected (seller tolak with reason → order continues)
///           → auto_accepted (seller diam 24 jam → order cancelled + refund)
///           → cancelled  (buyer mengundurkan request)
model CancelRequest {
  id          String    @id @default(cuid())
  orderId     String    @map("order_id")
  buyerId     String    @map("buyer_id")
  reason      String
  status      String    @default("pending")
  rejectNote  String?   @map("reject_note")
  expiresAt   DateTime  @map("expires_at") // pending → auto_accepted di waktu ini
  respondedAt DateTime? @map("responded_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, status])
  @@index([status, expiresAt])
  @@map("cancel_requests")
}

/// Buyer-initiated return after delivery. Multi-step state machine:
///   requested      — buyer ajukan retur, seller belum respond (timer 48h)
///   approved       — seller approve / auto-approve, buyer harus kirim balik (timer 5d)
///   shipped_back   — buyer input resi balik (timer 3d untuk seller konfirmasi)
///   completed      — seller konfirmasi terima / auto-confirm → refund
///   rejected       — seller tolak (masuk dispute)
///   expired        — buyer gagal kirim balik dalam 5 hari (transaksi lanjut)
model ReturnRequest {
  id                   String    @id @default(cuid())
  orderId              String    @map("order_id")
  buyerId              String    @map("buyer_id")
  reason               String
  description          String
  evidenceJson         String    @default("[]") @map("evidence_json")
  status               String    @default("requested")
  rejectNote           String?   @map("reject_note")
  responseDeadlineAt   DateTime  @map("response_deadline_at") // requested → auto-approve
  shipBackDeadlineAt   DateTime? @map("ship_back_deadline_at") // approved → expired
  confirmDeadlineAt    DateTime? @map("confirm_deadline_at") // shipped_back → auto-confirm
  returnTrackingNumber String?   @map("return_tracking_number")
  returnCourierCode    String?   @map("return_courier_code")
  shippedBackAt        DateTime? @map("shipped_back_at")
  approvedAt           DateTime? @map("approved_at")
  resolvedAt           DateTime? @map("resolved_at")
  createdAt            DateTime  @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, status])
  @@index([status, responseDeadlineAt])
  @@index([status, shipBackDeadlineAt])
  @@index([status, confirmDeadlineAt])
  @@map("return_requests")
}

model Payment {
  id           String    @id @default(cuid())
  orderId      String    @unique @map("order_id")
  provider     String    @default("midtrans")
  providerTxId String?   @unique @map("provider_tx_id")
  method       String?
  amountCents  BigInt    @map("amount_cents")
  statusRaw    String    @map("status_raw")
  paidAt       DateTime? @map("paid_at")
  payloadJson  String?   @map("payload_json")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

/// Admin-mediated dispute. Opened when buyer & seller can't agree on a
/// retur/damage claim. Decision values are limited to the three CS options:
///   refund_buyer_no_return — uang refund, barang tidak dikirim balik
///   refund_buyer_with_return — uang refund, buyer wajib kirim balik dulu
///   release_seller         — uang tetap ke seller, retur ditolak
model Dispute {
  id           String    @id @default(cuid())
  orderId      String    @unique @map("order_id")
  buyerId      String    @map("buyer_id")
  sellerId     String    @map("seller_id")
  kind         String    @default("damaged") // damaged | not_as_described | return_rejected | other
  reason       String
  description  String
  evidenceJson String    @default("[]") @map("evidence_json")
  status       String    @default("new") // new | reviewing | resolved
  decision     String?
  adminNote    String?   @map("admin_note")
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  buyer  User  @relation("BuyerDisputes", fields: [buyerId], references: [id])
  seller User  @relation("SellerDisputes", fields: [sellerId], references: [id])

  @@index([status, createdAt])
  @@map("disputes")
}

model Post {
  id            String    @id @default(cuid())
  authorId      String    @map("author_id")
  body          String
  imagesJson    String    @default("[]") @map("images_json")
  categoryId    String?   @map("category_id")
  likesCount    Int       @default(0) @map("likes_count")
  commentsCount Int       @default(0) @map("comments_count")
  viewsCount    Int       @default(0) @map("views_count")
  moderation    String    @default("pending")
  createdAt     DateTime  @default(now()) @map("created_at")
  deletedAt     DateTime? @map("deleted_at")

  author   User          @relation(fields: [authorId], references: [id])
  likes    PostLike[]
  comments PostComment[]

  @@index([authorId, createdAt])
  @@index([moderation, createdAt])
  @@map("posts")
}

model PostLike {
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId])
  @@map("post_likes")
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  authorId  String   @map("author_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("post_comments")
}

model Conversation {
  id        String               @id @default(cuid())
  createdAt DateTime             @default(now()) @map("created_at")
  messages  Message[]
  members   ConversationMember[]

  @@map("conversations")
}

model ConversationMember {
  conversationId String    @map("conversation_id")
  userId         String    @map("user_id")
  lastReadAt     DateTime? @map("last_read_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@map("conversation_members")
}

model Message {
  id             String    @id @default(cuid())
  conversationId String    @map("conversation_id")
  senderId       String    @map("sender_id")
  body           String
  attachmentUrl  String?   @map("attachment_url")
  createdAt      DateTime  @default(now()) @map("created_at")
  deletedAt      DateTime? @map("deleted_at")

  // Optional offer payload — when the message is a price-negotiation
  // proposal, kind="offer" and offerListingId/offerPriceCents are set.
  // Other kinds may follow (e.g. trade swap proposal). The recipient
  // accepts/rejects; status flips and downstream pages (checkout)
  // pick up the negotiated price.
  kind           String    @default("text") // text | offer | trade
  offerListingId String?   @map("offer_listing_id")
  offerPriceCents BigInt?  @map("offer_price_cents")
  offerStatus    String?   @map("offer_status") // pending | accepted | rejected | cancelled
  decidedAt      DateTime? @map("offer_decided_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  offerListing Listing?     @relation("MessageOfferListing", fields: [offerListingId], references: [id])

  @@index([conversationId, createdAt])
  @@index([offerListingId, offerStatus])
  @@map("messages")
}

model Report {
  id         String    @id @default(cuid())
  reporterId String    @map("reporter_id")
  targetType String    @map("target_type")
  targetId   String    @map("target_id")
  reason     String
  status     String    @default("open")
  severity   String    @default("mid")
  createdAt  DateTime  @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")

  reporter User @relation("ReporterReports", fields: [reporterId], references: [id])

  @@index([targetType, targetId])
  @@index([status, severity, createdAt])
  @@map("reports")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  kind      String
  title     String
  body      String
  dataJson  String?   @map("data_json")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@map("notifications")
}

model AuditEntry {
  id        String   @id @default(cuid())
  actorId   String?  @map("actor_id")
  action    String
  targetRef String   @map("target_ref")
  ip        String?
  metaJson  String?  @map("meta_json")
  createdAt DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id])

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@map("audit_entries")
}

model WebhookLog {
  id          String   @id @default(cuid())
  source      String
  event       String
  statusRaw   String   @map("status_raw")
  latencyMs   Int      @map("latency_ms")
  payloadJson String   @map("payload_json")
  signatureOk Boolean  @default(false) @map("signature_ok")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([source, createdAt])
  @@map("webhook_logs")
}

model FeatureFlag {
  key       String   @id
  enabled   Boolean  @default(false)
  note      String?
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("feature_flags")
}

model TradeProposal {
  id            String    @id @default(cuid())
  fromUserId    String    @map("from_user_id")
  toUserId      String    @map("to_user_id")
  fromListingId String    @map("from_listing_id")
  toListingId   String    @map("to_listing_id")
  message       String?
  status        String    @default("pending") // pending | accepted | declined | cancelled | expired
  respondedAt   DateTime? @map("responded_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([toUserId, status, createdAt])
  @@index([fromUserId, status, createdAt])
  @@index([fromListingId, toListingId])
  @@map("trade_proposals")
}

/// Swipe-left memory so the same candidate doesn't reappear in the deck.
/// Legacy from the wishlist-match flow; kept for back-compat only.
model TradePass {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  candidateUserId String   @map("candidate_user_id")
  fromListingId   String   @map("from_listing_id")
  toListingId     String   @map("to_listing_id")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([userId, fromListingId, toListingId])
  @@index([userId, createdAt])
  @@map("trade_passes")
}

/// Tinder-style swipe state. One row per (swiper, target listing) pair.
/// direction = "right" (interested) | "left" (pass). Right-swipes are the
/// signal we use to detect a mutual-interest match in TradesService.
model TradeSwipe {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  targetListingId String   @map("target_listing_id")
  // Owner of the targeted listing — denormalised so match queries don't
  // need to join Listing for every read.
  targetOwnerId   String   @map("target_owner_id")
  direction       String   // "right" | "left"
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([userId, targetListingId])
  @@index([targetOwnerId, direction])
  @@index([userId, createdAt])
  @@map("trade_swipes")
}

model PromoCode {
  id         String    @id @default(cuid())
  code       String    @unique
  kind       String
  value      Int
  minOrder   BigInt    @default(0) @map("min_order")
  usageLimit Int       @default(0) @map("usage_limit")
  used       Int       @default(0)
  startsAt   DateTime? @map("starts_at")
  endsAt     DateTime? @map("ends_at")
  active     Boolean   @default(true)

  @@map("promo_codes")
}

/// Singleton row (id = "singleton") holding admin-editable site branding +
/// short copy strings. Read by every page render (cached) so the admin can
/// rebrand without a deploy. copyJson is a flat string→string map keyed by
/// well-known constants in apps/web/lib/copy/keys.ts.
model SiteSettings {
  id             String   @id @default("singleton")
  brandName      String   @default("Hoobiq") @map("brand_name")
  logoUrl        String?  @map("logo_url")
  faviconUrl     String?  @map("favicon_url")
  primaryColor   String   @default("#FFA552") @map("primary_color")
  footerText     String   @default("© Hoobiq · Marketplace kolektor Indonesia") @map("footer_text")
  copyJson       String   @default("{}") @map("copy_json")
  updatedAt      DateTime @updatedAt @map("updated_at")
  updatedById    String?  @map("updated_by_id")

  @@map("site_settings")
}

// Boost purchase — seller buys a "promote my listing for N days" SKU.
// On Midtrans webhook settle, OrdersService extends Listing.boostedUntil
// from now() (or current boostedUntil if already boosted) by durationDays.
// providerTxId is the Midtrans order_id, prefixed with "BST-" so the
// webhook router can distinguish from regular orders.
model BoostPurchase {
  id             String   @id @default(cuid())
  listingId      String   @map("listing_id")
  userId         String   @map("user_id")
  durationDays   Int      @map("duration_days")
  priceCents     BigInt   @map("price_cents")
  providerTxId   String   @unique @map("provider_tx_id")
  status         String   @default("pending") // pending | paid | failed | cancelled
  paidAt         DateTime? @map("paid_at")
  startsAt       DateTime? @map("starts_at")
  endsAt         DateTime? @map("ends_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([listingId, status])
  @@map("boost_purchases")
}

/// Hero slider banner shown at the top of the logged-in home page.
/// CMS-managed via /admin-panel/homepage-banners — admins can add /
/// edit / reorder / activate-deactivate without a code deploy. The
/// public GET /banners endpoint returns the active set ordered by
/// sortOrder for the slider to render.
model HomepageBanner {
  id        String   @id @default(cuid())
  /// Bold heading on the banner ("Lengkapi Koleksimu...").
  title     String
  /// Smaller subtitle line below the heading (optional).
  subtitle  String?
  /// Small uppercase tag chip ("HOT COLLECTION", "FEATURED", ...).
  kicker    String?
  /// CTA button label ("Jelajahi Sekarang").
  ctaLabel  String   @default("Jelajahi Sekarang")
  /// Internal href the CTA goes to ("/marketplace?sort=trending").
  ctaHref   String   @default("/marketplace")
  /// Hero image — typically a product collage uploaded by admin.
  imageUrl  String   @map("image_url")
  /// Display order — lower = earlier in the slider rotation.
  sortOrder Int      @default(0) @map("sort_order")
  /// Toggle to hide a banner without deleting it (e.g. seasonal swaps).
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([active, sortOrder])
  @@map("homepage_banners")
}
