# ===========================================================================
# Hoobiq API — production environment template
# Copy this file to /var/www/hoobiq/apps/api/.env on the VPS and fill in the
# real values. NEVER commit the real .env to git.
# ===========================================================================

NODE_ENV=production
PORT=4000

# ---- Database (local Postgres on the VPS) ---------------------------------
# The setup-vps.sh script creates db `hoobiq` with user `hoobiq`.
DATABASE_URL="postgresql://hoobiq:REPLACE_DB_PASSWORD@localhost:5432/hoobiq?schema=public"

# ---- Redis (local on the VPS) ---------------------------------------------
REDIS_URL="redis://localhost:6379"

# ---- Auth secrets (generate with: openssl rand -base64 48) -----------------
SESSION_COOKIE_NAME=hbq_session
SESSION_SECRET=REPLACE_GENERATE_64_CHAR_RANDOM
SESSION_TTL_DAYS=30
PASSWORD_PEPPER=REPLACE_GENERATE_32_CHAR_RANDOM
CSRF_SECRET=REPLACE_GENERATE_64_CHAR_RANDOM

# ---- CORS — production origins only ---------------------------------------
WEB_ORIGIN=https://hoobiq.com
ADMIN_ORIGIN=https://admin.hoobiq.com

# ---- Public API base — used to build absolute URLs for assets the API serves
PUBLIC_API_BASE=https://api.hoobiq.com

# ---- Midtrans (production keys) -------------------------------------------
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_SIGNATURE_KEY=

# ---- Komerce (production keys) --------------------------------------------
KOMERCE_API_KEY=
KOMERCE_WEBHOOK_SECRET=

# ---- Cloudflare R2 --------------------------------------------------------
R2_ACCOUNT_ID=00b583bc99796f4001eb6233340c5787
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=hoobiq-prod
R2_PUBLIC_URL=https://cdn.hoobiq.com

# ---- Google OAuth ---------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
